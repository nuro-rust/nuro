{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nuro.dev/contracts/proposal-review.schema.json",
  "title": "Proposal Review Contract",
  "description": "Contract for layer-aware feature proposal and review records.",
  "type": "object",
  "required": [
    "proposal_id",
    "feature_title",
    "owned_layer",
    "scope_boundary",
    "api_impact",
    "compatibility_classification",
    "test_plan",
    "doc_plan",
    "acceptance_criteria"
  ],
  "additionalProperties": false,
  "properties": {
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "feature_title": {
      "type": "string",
      "minLength": 1
    },
    "owned_layer": {
      "type": "string",
      "enum": [
        "core",
        "capability",
        "runtime",
        "platform"
      ]
    },
    "scope_boundary": {
      "type": "string",
      "minLength": 1
    },
    "api_impact": {
      "type": "string",
      "minLength": 1
    },
    "compatibility_classification": {
      "type": "string",
      "enum": [
        "non_breaking",
        "deprecation_compatible",
        "breaking"
      ]
    },
    "requires_migration_guide": {
      "type": "boolean",
      "default": false
    },
    "replacement_path": {
      "type": "string"
    },
    "test_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "doc_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "compatibility_classification": {
            "const": "breaking"
          }
        },
        "required": [
          "compatibility_classification"
        ]
      },
      "then": {
        "required": [
          "requires_migration_guide"
        ],
        "properties": {
          "requires_migration_guide": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "compatibility_classification": {
            "const": "deprecation_compatible"
          }
        },
        "required": [
          "compatibility_classification"
        ]
      },
      "then": {
        "required": [
          "replacement_path"
        ],
        "properties": {
          "replacement_path": {
            "minLength": 1
          }
        }
      }
    }
  ]
}
