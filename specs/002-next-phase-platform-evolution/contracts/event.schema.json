{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nuro Event v1",
  "type": "object",
  "required": [
    "event_id",
    "schema_version",
    "timestamp_ms",
    "metadata",
    "kind"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "session_id": {
      "type": ["string", "null"]
    },
    "run_id": {
      "type": ["string", "null"]
    },
    "correlation_id": {
      "type": ["string", "null"]
    },
    "causation_id": {
      "type": ["string", "null"]
    },
    "metadata": {
      "type": "object"
    },
    "kind": {
      "oneOf": [
        {
          "type": "object",
          "required": ["LlmRequest"],
          "properties": {
            "LlmRequest": {
              "type": "object"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["LlmResponse"],
          "properties": {
            "LlmResponse": {
              "type": "object"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["ToolCallStart"],
          "properties": {
            "ToolCallStart": {
              "type": "object"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["ToolCallEnd"],
          "properties": {
            "ToolCallEnd": {
              "type": "object"
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
